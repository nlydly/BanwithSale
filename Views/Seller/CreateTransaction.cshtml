@model BanwithSale.Models.Transaction

@{
    ViewData["Title"] = "Add Transaction";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">Add New Transaction</h3>
                </div>
                <div class="card-body">

                    <form asp-controller="Seller" asp-action="CreateTransaction" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="form-group mb-3">
                            <label class="form-label font-weight-bold">User ID</label>
                            <input name="userId" type="number" class="form-control" placeholder="Enter User ID (e.g., 1)" required />
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label font-weight-bold">Description</label>
                            <input name="description" class="form-control" placeholder="e.g. Premium Plan Sold" required />
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label font-weight-bold">Amount (Kyats)</label>
                            <input name="amount" type="number" step="0.01" class="form-control" placeholder="0.00" required />
                        </div>

                        <div class="form-group mb-4">
                            <label class="form-label font-weight-bold">Date</label>
                            <input name="transactionDate" type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                        </div>

                        <div class="d-flex justify-content-between">
                            <button type="submit" class="btn btn-primary px-4">Save Transaction</button>
                            <a asp-controller="Seller" asp-action="Index" class="btn btn-primary px-4">Cancel</a>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>
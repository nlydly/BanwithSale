    <h5 class="mt-4 mb-3">Recent Activity</h5>
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Date</th>
                <th>Buyer</th>
                <th>Amount</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in ViewBag.RecentSales)
            {
                <tr>
                    <td>@item.TransactionDate.ToShortDateString()</td>
                    <td>@item.Description</td>
                    <td class="text-success">Ks @item.Amount</td>
                    <td>
                        <a href="/Seller/EditTransaction/@item.Id" class="btn btn-warning btn-sm">Edit</a>
                        <a href="/Seller/DeleteTransaction/@item.Id"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('Are you sure you want to delete this record?')">
                            Delete
                        </a>
                    </td>

                    <td>
                        <a asp-controller="EarningControllers"
                           asp-action="Edit"
                           asp-route-id="Id"
                           class="btn btn-warning btn-sm">Edit</a>

                        <a asp-controller="EarningControllers"
                           asp-action="Delete"
                           asp-route-id="Id"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('Are you sure you want to delete this record?');">Delete</a>
                    </td>



                </tr>
            }
        </tbody>
    </table>


</div>
@{
    ViewData["Title"] = "Seller Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<div class="container py-4">
    <h2>Seller Dashboard</h2>
    <h4>Welcome, @ViewBag.UserName 👋</h4>

    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <h5>TOTAL EARNINGS</h5>
                    <h3 class="text-success">Ks @ViewBag.TotalEarnings</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <h5>THIS MONTH</h5>
                    <h3 class="text-primary">Ks @ViewBag.ThisMonthEarnings</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <h5>BANDWIDTH SOLD</h5>
                    <h3>@ViewBag.BandwidthSold GB</h3>
                </div>
            </div>
        </div>
    </div>

   @*  <!-- Recent Activity -->
    <h5 class="mt-5 mb-3">Recent Activity</h5>
